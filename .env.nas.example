# NAS / Compose 最小部署配置
# 生成：openssl rand -hex 32
PAYLOAD_SECRET=CHANGE_ME_USE_OPENSSL_RAND_HEX_32

# NAS 内网试跑：改成你的 NAS IP；正式公网建议改成 HTTPS 域名
APP_PORT=8787
SERVER_URL=http://NAS_IP:8787
NEXT_PUBLIC_SERVER_URL=http://NAS_IP:8787

# 数据库密码：首次部署前改掉；compose 会自动拼 DATABASE_URL
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
